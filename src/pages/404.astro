---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Lost truck — Hawai‘i Mobile Food Foundation">
  <main class="min-h-screen flex items-center justify-center"
        style="background: var(--color-cream);">
    <div class="container-x text-center max-w-xl py-24">
      <span class="eyebrow">404</span>
      <h1 class="display-xl" style="color: var(--color-brand-red); margin-bottom: 16px;">Lost truck.</h1>
      <p class="font-sans text-[18px] leading-[1.55]" style="color: var(--color-ink-soft);">
        The page you’re looking for isn’t parked here — but the work still is.
      </p>
      <a href="/" class="btn btn-primary mt-8">← Back to the Foundation</a>
    </div>
  </main>
</BaseLayout>

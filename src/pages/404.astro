---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Lost truck — Hawaii Mobile Food Foundation">
  <main class="min-h-screen flex items-center justify-center bg-cream text-ink paper-noise">
    <div class="container-x text-center max-w-xl">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-lava mb-5">404</p>
      <h1 class="text-display-lg leading-[0.95]" style="text-wrap: balance;">
        That truck<br/>
        <span class="italic text-ulu">isn’t parked here.</span>
      </h1>
      <p class="mt-6 text-stone text-lg">
        The page you’re looking for doesn’t exist — but the work does.
      </p>
      <a href="/" class="btn btn-vendor mt-9">← Back to the Foundation</a>
    </div>
  </main>
</BaseLayout>

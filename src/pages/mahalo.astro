---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Mahalo — Hawai‘i Mobile Food Foundation">
  <main class="min-h-screen flex items-center justify-center"
        style="background: var(--color-cream-soft);">
    <div class="container-x text-center max-w-2xl py-24">
      <span class="eyebrow">Received</span>
      <h1 class="display-xl" style="color: var(--color-brand-red); margin-bottom: 16px;">Mahalo!</h1>
      <p class="font-sans text-[18px] leading-[1.55] max-w-prose mx-auto" style="color: var(--color-ink-soft);">
        Your message landed. A real human will get back to you within a week — usually
        faster. In the meantime, watch for the next episode announcement.
      </p>
      <a href="/" class="btn btn-ghost mt-8">← Back to the Foundation</a>
    </div>
  </main>
</BaseLayout>

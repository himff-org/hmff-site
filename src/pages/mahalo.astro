---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Mahalo — Hawaii Mobile Food Foundation">
  <main class="min-h-screen flex items-center justify-center bg-ink text-cream relative overflow-hidden topo">
    <div aria-hidden="true"
         class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2
                bg-[radial-gradient(ellipse_at_50%_100%,rgba(226,178,58,0.18),transparent_60%)]"></div>

    <div class="container-x relative text-center max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-gold mb-5">Received</p>
      <h1 class="text-display-lg md:text-display-xl leading-[0.95]" style="text-wrap: balance;">
        Mahalo,<br/>
        <span class="italic text-gold">a hui hou.</span>
      </h1>
      <p class="mt-7 text-cream/80 text-lg">
        Your message landed. A real human will get back to you within a week — usually faster.
        In the meantime, watch for the next rally announcement.
      </p>
      <a href="/" class="btn btn-ghost mt-10 !text-cream !border-cream/30 hover:!bg-cream/10">
        ← Back to the Foundation
      </a>
    </div>
  </main>
</BaseLayout>

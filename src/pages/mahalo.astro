---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Mahalo — Hawaii Mobile Food Foundation">
  <main class="min-h-screen flex items-center justify-center hero-halo paper-noise relative overflow-hidden">
    <div class="container-x relative text-center max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-lava mb-5">Received</p>
      <h1 class="text-display-lg md:text-display-xl leading-[0.95] text-ink" style="text-wrap: balance;">
        Mahalo,<br/>
        <span class="italic text-lava">a hui hou.</span>
      </h1>
      <p class="mt-7 text-stone text-lg max-w-prose mx-auto">
        Your message landed. A real human will get back to you within a week — usually faster.
        In the meantime, watch for the next rally announcement.
      </p>
      <a href="/" class="btn btn-ghost mt-10">
        ← Back to the Foundation
      </a>
    </div>
  </main>
</BaseLayout>

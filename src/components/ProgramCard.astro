---
interface Props {
  title: string;
  body: string;
  cta: { label: string; href: string };
  audience: "vendor" | "donor" | "both";
  icon: "kit" | "rally" | "advocacy" | "story";
  meta?: string;
}
const { title, body, cta, audience, icon, meta } = Astro.props;

const accent = audience === "vendor" ? "var(--color-ulu)"
              : audience === "donor"  ? "var(--color-lava)"
              : "var(--color-gold)";
const ctaClass = audience === "donor" ? "btn-donor" : "btn-vendor";
---
<article class="group surface relative flex flex-col p-7 md:p-9 hover:-translate-y-1 transition-transform duration-300 overflow-hidden">
  <!-- accent corner glow -->
  <span aria-hidden="true"
        class="absolute -top-12 -right-12 h-32 w-32 rounded-full opacity-20 blur-2xl transition-opacity group-hover:opacity-35"
        style={`background: ${accent};`}></span>

  <div class="relative">
    <div class="flex items-center justify-between mb-6">
      <div class="h-12 w-12 rounded-2xl flex items-center justify-center"
           style={`background: color-mix(in srgb, ${accent} 12%, transparent); color: ${accent};`}>
        {icon === "kit" && (
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 8h16v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V8z"/>
            <path d="M9 8V5a3 3 0 0 1 6 0v3"/>
            <path d="M9 13h6"/>
          </svg>
        )}
        {icon === "rally" && (
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="8" r="3"/>
            <circle cx="17" cy="9" r="2.2"/>
            <path d="M3 20c0-3.3 2.7-5 6-5s6 1.7 6 5"/>
            <path d="M14 20c0-2.4 1.5-4 3.5-4s3.5 1.6 3.5 4"/>
          </svg>
        )}
        {icon === "advocacy" && (
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v4M5 5l3 3M19 5l-3 3M3 12h4M17 12h4M12 22a8 8 0 0 0 8-8H4a8 8 0 0 0 8 8z"/>
          </svg>
        )}
        {icon === "story" && (
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="6" width="14" height="12" rx="2"/>
            <path d="m17 11 4-2v6l-4-2z"/>
          </svg>
        )}
      </div>
      {meta && (
        <span class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-stone">{meta}</span>
      )}
    </div>

    <h3 class="font-display text-2xl md:text-[1.7rem] leading-tight text-ink mb-3" style="font-variation-settings: 'opsz' 60;">
      {title}
    </h3>
    <p class="text-stone text-[0.96rem] leading-relaxed mb-6">{body}</p>

    <a href={cta.href} class={`btn ${ctaClass} !py-2.5 !px-5 text-sm self-start mt-auto`}>
      {cta.label}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

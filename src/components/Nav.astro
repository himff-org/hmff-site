---
import Logo from "./Logo.astro";

const links = [
  { href: "#podcast", label: "Podcast" },
  { href: "#programs", label: "Programs" },
  { href: "#vendors", label: "Vendors" },
  { href: "#about", label: "About" },
];
---
<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent">
  <div class="container-x flex items-center gap-6 py-4">
    <a href="#top" class="no-underline" aria-label="Hawai‘i Mobile Food Foundation — home">
      <Logo size={32} />
    </a>

    <ul class="hidden md:flex items-center gap-7 list-none m-0 p-0 ml-6">
      {links.map((l) => (
        <li>
          <a href={l.href}
             class="font-sans font-medium text-[15px] text-ink no-underline hover:no-underline border-b-2 border-transparent hover:border-brand-red pb-1 transition-colors">
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="ml-auto flex items-center gap-2.5">
      <a href="#vendors" class="hidden sm:inline-flex btn btn-utility">Vendor sign in</a>
      <a href="#support" class="btn btn-primary">Donate</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("site-nav");
  if (nav) {
    const update = () => {
      const scrolled = window.scrollY > 24;
      if (scrolled) {
        nav.style.background = "rgba(255, 247, 232, 0.92)";
        nav.style.backdropFilter = "blur(12px)";
        (nav.style as any).webkitBackdropFilter = "blur(12px)";
        nav.classList.add("border-ink/10");
      } else {
        nav.style.background = "transparent";
        nav.style.backdropFilter = "none";
        (nav.style as any).webkitBackdropFilter = "none";
        nav.classList.remove("border-ink/10");
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  }
</script>

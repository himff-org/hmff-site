---
interface Props {
  size?: "md" | "lg";
  align?: "left" | "center";
  vendorHref?: string;
  donorHref?: string;
  vendorLabel?: string;
  donorLabel?: string;
}

const {
  size = "md",
  align = "left",
  vendorHref = "#vendors",
  donorHref = "#support",
  vendorLabel = "I run a food truck",
  donorLabel = "I want to support",
} = Astro.props;

const sizeClass = size === "lg" ? "!py-4 !px-7 text-base" : "";
const alignClass = align === "center" ? "justify-center" : "justify-start";
---
<div class={`flex flex-wrap gap-3 ${alignClass}`}>
  <a href={vendorHref} class={`btn btn-vendor ${sizeClass}`}>
    <svg viewBox="0 0 20 20" class="h-4 w-4" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M3 13h14M5 13V8h10v5M7 8V5h6v3M6 17v-2M14 17v-2" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="6" cy="15" r="1.5" fill="currentColor"/>
      <circle cx="14" cy="15" r="1.5" fill="currentColor"/>
    </svg>
    {vendorLabel}
    <span aria-hidden="true">→</span>
  </a>
  <a href={donorHref} class={`btn btn-donor ${sizeClass}`}>
    <svg viewBox="0 0 20 20" class="h-4 w-4" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M10 17s-6-4-6-9a3 3 0 0 1 6-1 3 3 0 0 1 6 1c0 5-6 9-6 9z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    {donorLabel}
    <span aria-hidden="true">→</span>
  </a>
</div>

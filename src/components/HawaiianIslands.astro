---
interface Props {
  /** Override classes on the outer SVG (sizing, opacity, etc.) */
  class?: string;
  /** Show the small "Hawai'i Island" label connecting to Big Island */
  showLabel?: boolean;
}

const { class: className = "", showLabel = true } = Astro.props;
---
<svg
  viewBox="0 0 1200 360"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="hi-title hi-desc"
  class={className}
>
  <title id="hi-title">The Hawaiian Islands</title>
  <desc id="hi-desc">
    A simplified silhouette of the eight main Hawaiian Islands, with Hawai‘i
    Island (the Big Island) highlighted to show the Foundation's home base.
  </desc>

  <defs>
    <linearGradient id="bigislandFill" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#E66B52"/>
      <stop offset="100%" stop-color="#D9472B"/>
    </linearGradient>
    <linearGradient id="islandFill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#E8DCC2"/>
      <stop offset="100%" stop-color="#D7C8A4"/>
    </linearGradient>
    <filter id="islandShadow" x="-20%" y="-20%" width="140%" height="160%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="3"/>
      <feOffset dx="0" dy="3" result="offsetblur"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.18"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="bigShadow" x="-20%" y="-20%" width="140%" height="160%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="6"/>
      <feOffset dx="0" dy="6" result="offsetblur"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.30"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- Subtle ocean dotted line connecting the chain -->
  <path
    d="M 70 160 Q 250 110, 470 175 T 870 215"
    fill="none"
    stroke="rgba(191, 216, 229, 0.55)"
    stroke-width="2"
    stroke-linecap="round"
    stroke-dasharray="2 8"
  />

  <g filter="url(#islandShadow)">
    <!-- Niʻihau (NW-most, small) -->
    <path
      d="M 55 155
         q 8 -16 22 -10
         q 14 6 14 22
         q -2 14 -16 18
         q -16 4 -22 -10
         q -6 -12 2 -20 z"
      fill="url(#islandFill)"
    />

    <!-- Kauaʻi (round mountain) -->
    <path
      d="M 130 145
         q 16 -22 44 -16
         q 28 6 36 28
         q 6 22 -10 38
         q -22 18 -50 8
         q -22 -8 -28 -28
         q -4 -18 8 -30 z"
      fill="url(#islandFill)"
    />

    <!-- Oʻahu (two ridges, distinctive) -->
    <path
      d="M 250 158
         q 10 -18 30 -18
         q 20 0 28 14
         q 12 -2 20 8
         q 10 16 0 30
         q -10 16 -28 14
         q -22 -2 -38 -14
         q -18 -16 -12 -34 z"
      fill="url(#islandFill)"
    />

    <!-- Molokaʻi (long thin E-W) -->
    <path
      d="M 380 175
         q 30 -10 70 -6
         q 40 4 60 4
         q 18 4 18 14
         q 0 12 -22 14
         q -36 4 -76 0
         q -40 -4 -52 -10
         q -10 -8 2 -16 z"
      fill="url(#islandFill)"
    />

    <!-- Lānaʻi (small oval) -->
    <path
      d="M 490 222
         q 8 -14 24 -12
         q 18 2 22 16
         q 2 14 -12 20
         q -16 6 -28 -4
         q -10 -10 -6 -20 z"
      fill="url(#islandFill)"
    />

    <!-- Kahoʻolawe (smallest, bottom) -->
    <path
      d="M 540 268
         q 6 -10 18 -8
         q 14 2 14 12
         q -2 10 -14 12
         q -14 2 -20 -6
         q -4 -6 2 -10 z"
      fill="url(#islandFill)"
    />

    <!-- Maui (figure-8 silhouette) -->
    <path
      d="M 590 200
         q 14 -22 38 -22
         q 22 0 30 16
         q 14 -8 32 -2
         q 24 8 30 30
         q 4 22 -18 32
         q -22 8 -42 -2
         q -10 14 -30 12
         q -26 -2 -38 -22
         q -10 -22 -2 -42 z"
      fill="url(#islandFill)"
    />
  </g>

  <!-- ── Hawaiʻi Island (the Big Island, highlighted) ── -->
  <g filter="url(#bigShadow)">
    <path
      d="M 800 195
         q 30 -34 80 -28
         q 50 6 78 36
         q 30 32 28 76
         q -2 50 -38 78
         q -42 32 -92 16
         q -56 -18 -76 -64
         q -16 -44 0 -82
         q 8 -22 20 -32 z"
      fill="url(#bigislandFill)"
    />
    <!-- inner highlight -->
    <path
      d="M 830 215
         q 22 -18 56 -10
         q 32 8 48 32"
      fill="none"
      stroke="rgba(255, 255, 255, 0.30)"
      stroke-width="3"
      stroke-linecap="round"
    />
    <!-- center marker -->
    <circle cx="870" cy="245" r="5" fill="#FFFFFF"/>
    <circle cx="870" cy="245" r="11" fill="none" stroke="rgba(255, 255, 255, 0.45)" stroke-width="2"/>
  </g>

  {showLabel && (
    <g>
      <!-- thin connector line from marker to label -->
      <path
        d="M 884 245 Q 940 245, 970 230"
        stroke="rgba(14, 27, 44, 0.25)"
        stroke-width="1"
        fill="none"
        stroke-linecap="round"
      />
      <text
        x="976"
        y="226"
        font-family="DM Mono, monospace"
        font-size="13"
        font-weight="500"
        letter-spacing="2.4"
        fill="#0E1B2C"
        opacity="0.78"
      >HAWAIʻI ISLAND</text>
      <text
        x="976"
        y="246"
        font-family="DM Mono, monospace"
        font-size="11"
        letter-spacing="2"
        fill="#5B6470"
      >home of the foundation</text>
    </g>
  )}
</svg>

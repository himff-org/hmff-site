---
interface Props {
  class?: string;
  showLabel?: boolean;
}
const { class: className = "", showLabel = true } = Astro.props;
---
<svg
  viewBox="-30 0 2360 1300"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="hi-title hi-desc"
  class={className}
>
  <title id="hi-title">The Hawaiian Islands</title>
  <desc id="hi-desc">
    A silhouette of the eight main Hawaiian Islands, with Hawai‘i Island
    (the Big Island) highlighted to show the Foundation’s home base.
  </desc>
  <defs>
    <linearGradient id="bigFill" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#E66B52"/>
      <stop offset="100%" stop-color="#D9472B"/>
    </linearGradient>
    <linearGradient id="islandFill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#E8DCC2"/>
      <stop offset="100%" stop-color="#CBB78F"/>
    </linearGradient>
    <filter id="islandShadow" x="-15%" y="-15%" width="130%" height="135%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="6"/>
      <feOffset dx="0" dy="6" result="offsetblur"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.18"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="bigShadow" x="-15%" y="-15%" width="130%" height="135%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="14"/>
      <feOffset dx="0" dy="14" result="offsetblur"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.30"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>


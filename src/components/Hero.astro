---
// Hero: full-bleed warm photograph + Sigmar headline + protection gradient
const heroImg = "https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=1920&q=80&auto=format&fit=crop";
---
<section id="top" class="site-hero relative isolate overflow-hidden flex items-end" style="min-height: 92svh;">
  <img
    src={heroImg}
    alt="A Hawai‘i food truck at golden hour — light from the order window, hands working inside."
    class="site-hero-img absolute inset-0 w-full h-full object-cover -z-20"
    style="filter: saturate(1.05) contrast(1.02) brightness(0.62);"
  />
  <!-- protection gradient: vertical darken + left-side darken so the text column always sits on a dark patch -->
  <div aria-hidden="true" class="site-hero-grad absolute inset-0 -z-10"
       style="background: linear-gradient(180deg, rgba(42,26,14,0.45) 0%, rgba(42,26,14,0.25) 25%, rgba(42,26,14,0.55) 60%, rgba(42,26,14,0.95) 100%), linear-gradient(90deg, rgba(42,26,14,0.65) 0%, rgba(42,26,14,0.25) 55%, rgba(42,26,14,0) 85%);"></div>

  <div class="site-hero-content container-x py-24 md:py-28 pt-36 md:pt-40 relative z-10 text-cream">
    <p class="eyebrow eyebrow-light fade-up">Hawai‘i Mobile Food Foundation</p>

    <h1 class="site-hero-h display-xl mb-6 max-w-[20ch] fade-up"
        style="text-shadow: 0 2px 0 rgba(42,26,14,0.6), 0 4px 16px rgba(42,26,14,0.85), 0 12px 40px rgba(42,26,14,0.7); animation-delay: 60ms;">
      Mobile food in Hawai‘i,<br/>
      <span style="color: var(--color-brand-yellow);">made easier for the folks cooking.</span>
    </h1>

    <p class="site-hero-sub mb-8 max-w-[46ch] text-[19px] md:text-[20px] leading-[1.55] font-medium text-cream fade-up"
       style="text-shadow: 0 1px 2px rgba(42,26,14,0.85), 0 2px 16px rgba(42,26,14,0.7); animation-delay: 140ms;">
      Hawai‘i’s food-truck vendors are great cooks and great with their customers —
      that’s where their time and attention belong. The Hawai‘i Mobile Food Foundation
      handles the side of the business that isn’t the food itself: marketing courses for
      vendors, and a long-form podcast about the people behind every truck.
    </p>

    <div class="flex flex-wrap gap-3 fade-up" style="animation-delay: 220ms;">
      <a href="#podcast" class="btn btn-primary">
        <svg viewBox="0 0 20 20" class="h-4 w-4" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="10" cy="10" r="8"/>
          <path d="M8 7l5 3-5 3z" fill="currentColor"/>
        </svg>
        Listen to the podcast
      </a>
      <a href="#vendors" class="btn btn-ghost-light">I run a truck</a>
    </div>
  </div>
</section>

---
import DonateButton from "./DonateButton.astro";

const tiers = [
  { name: "Friend",            amount: "$25–$249",   pitch: "Buys signage, ServSafe vouchers, and rally permits.", icon: "•" },
  { name: "Rally Sponsor",     amount: "$250–$2,499", pitch: "Underwrites a quarterly rally, naming optional.",     icon: "◆" },
  { name: "Founding Partner",  amount: "$2,500+",    pitch: "Multi-year partnerships. Logo placement, board reports, joint comms.", icon: "★" },
  { name: "Grant Inquiry",     amount: "Foundations",pitch: "We file proposals for permit-help, training, and storytelling work.", icon: "✦" },
];

const formspreeEndpoint = import.meta.env.PUBLIC_FORMSPREE_DONOR ?? "";
const action = formspreeEndpoint || "mailto:hello@hawaiimobilefoodfoundation.org";
---
<section id="support" class="section bg-cream-deep/30 scroll-mt-20 relative overflow-hidden">
  <div class="container-x grid lg:grid-cols-12 gap-12">
    <div class="lg:col-span-5">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-lava mb-4">For supporters</p>
      <h2 class="text-display-md md:text-display-lg leading-[1.05]" style="text-wrap: balance;">
        Back the<br/>
        <span class="italic text-lava">people who feed</span> us.
      </h2>
      <p class="mt-6 text-stone text-lg leading-relaxed max-w-md">
        Every dollar funds welcome kits, rally permits, and ‘Ōlelo-narrated mini-docs that
        keep this work visible. <strong class="text-ink">HMFF is a confirmed 501(c)(3)</strong> —
        contributions are tax-deductible to the fullest extent allowed by law.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <DonateButton size="lg" />
        <a href="#sponsor-form" class="btn btn-ghost !py-4 !px-7 text-base">
          Sponsor or partner
        </a>
      </div>

      <p class="mt-6 text-xs font-mono uppercase tracking-[0.18em] text-stone">
        EIN forthcoming · Receipts via Stripe
      </p>
    </div>

    <div class="lg:col-span-7 grid sm:grid-cols-2 gap-4 self-start">
      {tiers.map((t) => (
        <div class="rounded-2xl border border-ink/10 bg-cream p-6 hover:border-lava/40 transition-colors">
          <div class="flex items-start justify-between gap-3 mb-2">
            <h3 class="font-display text-xl md:text-2xl text-ink" style="font-variation-settings: 'opsz' 60;">
              {t.name}
            </h3>
            <span class="text-lava text-xl leading-none" aria-hidden="true">{t.icon}</span>
          </div>
          <p class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-lava mb-3">{t.amount}</p>
          <p class="text-sm text-stone leading-relaxed">{t.pitch}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Sponsor / partner form -->
  <div id="sponsor-form" class="container-x mt-20 scroll-mt-20">
    <div class="max-w-3xl mx-auto bg-ink text-cream rounded-3xl p-8 md:p-10 shadow-2xl shadow-ink/30">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-gold mb-3">Sponsor / Grant inquiry</p>
      <h3 class="font-display text-2xl md:text-3xl mb-3" style="font-variation-settings: 'opsz' 60;">
        Let’s talk about a partnership.
      </h3>
      <p class="text-cream/75 text-sm mb-6 max-w-prose">
        For one-off rally sponsorships, multi-year partnerships, or grant proposals — leave a note
        and the right person here will reply within a week.
      </p>

      <form class="grid sm:grid-cols-2 gap-4" action={action} method={action.startsWith("http") ? "POST" : "post"}>
        <label class="block">
          <span class="block font-mono text-[0.7rem] uppercase tracking-[0.18em] text-cream/60 mb-1.5">Name</span>
          <input required name="name" type="text" autocomplete="name"
                 class="w-full px-4 py-3 rounded-xl border border-cream/20 bg-cream/5 text-cream placeholder:text-cream/40 focus:outline-none focus:border-lava focus:ring-2 focus:ring-lava/20 transition"/>
        </label>
        <label class="block">
          <span class="block font-mono text-[0.7rem] uppercase tracking-[0.18em] text-cream/60 mb-1.5">Organization</span>
          <input name="org" type="text"
                 class="w-full px-4 py-3 rounded-xl border border-cream/20 bg-cream/5 text-cream placeholder:text-cream/40 focus:outline-none focus:border-lava focus:ring-2 focus:ring-lava/20 transition"/>
        </label>
        <label class="block sm:col-span-2">
          <span class="block font-mono text-[0.7rem] uppercase tracking-[0.18em] text-cream/60 mb-1.5">Email</span>
          <input required name="email" type="email" autocomplete="email"
                 class="w-full px-4 py-3 rounded-xl border border-cream/20 bg-cream/5 text-cream placeholder:text-cream/40 focus:outline-none focus:border-lava focus:ring-2 focus:ring-lava/20 transition"/>
        </label>
        <label class="block sm:col-span-2">
          <span class="block font-mono text-[0.7rem] uppercase tracking-[0.18em] text-cream/60 mb-1.5">What are you thinking?</span>
          <textarea required name="message" rows="4"
                    class="w-full px-4 py-3 rounded-xl border border-cream/20 bg-cream/5 text-cream placeholder:text-cream/40 focus:outline-none focus:border-lava focus:ring-2 focus:ring-lava/20 transition resize-y"
                    placeholder="Sponsor a rally? Grant we should pursue? Multi-year partnership?"></textarea>
        </label>

        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" />
        <input type="hidden" name="_subject" value="HMFF: New sponsor / grant inquiry" />
        <input type="hidden" name="_next" value="/mahalo" />

        <div class="sm:col-span-2 flex justify-end">
          <button type="submit" class="btn btn-donor">
            Send the inquiry
            <span aria-hidden="true">→</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

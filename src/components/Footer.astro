---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---
<footer class="text-cream" style="background: var(--color-brand-red); padding: 80px 0 32px;">
  <div class="container-x">
    <div class="grid md:grid-cols-12 gap-12 mb-14">
      <div class="md:col-span-5">
        <Logo variant="light" size={36} />
        <p class="mt-4 font-sans text-sm leading-[1.6] max-w-sm" style="color: rgba(255,247,232,0.78);">
          A Hawai‘i 501(c)(3) telling the human stories behind the islands’ food trucks —
          long-form on the site, short-form on Na Leo TV. Contributions are tax-deductible
          to the fullest extent allowed by law.
        </p>
        <p class="mt-4 font-sans text-[13px] leading-[1.6]" style="color: rgba(255,247,232,0.62);">
          PO Box 59 · Papaikou, HI 96781<br/>
          <a href="mailto:hello@hawaiimobilefoodfoundation.org"
             class="no-underline" style="color: rgba(255,247,232,0.78);">
            hello@hawaiimobilefoodfoundation.org
          </a>
        </p>
      </div>

      <div class="md:col-span-2">
        <h4 class="font-sans font-bold text-[13px] uppercase tracking-[0.1em] mb-4" style="color: var(--color-brand-yellow);">About</h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
          <li><a href="#about" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Mission</a></li>
          <li><a href="#about" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Board & legal</a></li>
          <li><a href="#faq" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">FAQ</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="font-sans font-bold text-[13px] uppercase tracking-[0.1em] mb-4" style="color: var(--color-brand-yellow);">For vendors</h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
          <li><a href="#vendors" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Get in touch</a></li>
          <li><a href="#programs" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Marketing course</a></li>
          <li><a href="#podcast" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Be on the show</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="font-sans font-bold text-[13px] uppercase tracking-[0.1em] mb-4" style="color: var(--color-brand-yellow);">Get involved</h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
          <li><a href="#support" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Donate</a></li>
          <li><a href="#support" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Sponsor an episode</a></li>
          <li><a href="#support" class="text-sm no-underline hover:underline" style="color: rgba(255,247,232,0.82);">Grant inquiries</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 pt-6 font-sans text-[13px]"
         style="border-top: 1px solid rgba(255,247,232,0.14); color: rgba(255,247,232,0.62);">
      <p>© {year} Hawai‘i Mobile Food Foundation · Mahalo for being here.</p>
      <p class="text-[12px]">501(c)(3) Hawai‘i · Built with Astro on GitHub Pages</p>
    </div>
  </div>
</footer>

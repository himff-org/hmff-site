---
interface Props {
  /** "dark" = red wordmark on cream/light bg. "light" = yellow wordmark on red/dark bg. */
  variant?: "dark" | "light";
  /** Pixel size for the wordmark text */
  size?: number;
  showLockup?: boolean;
}
const { variant = "dark", size = 32, showLockup = false } = Astro.props;
const wmColor = variant === "light" ? "var(--color-brand-yellow)" : "var(--color-brand-red)";
const lockupColor = variant === "light" ? "rgba(255,247,232,0.85)" : "var(--color-ink)";
---
<span class="inline-flex items-baseline gap-1.5 leading-none" aria-label="Hawai‘i Mobile Food Foundation">
  <span class="inline-block leading-none"
        style={`font-family: var(--font-display); color: ${wmColor}; font-size: ${size}px;`}>
    HiMFF
  </span>
  {showLockup && (
    <span class="hidden md:inline ml-2 font-sans font-semibold text-xs uppercase tracking-[0.14em]" style={`color: ${lockupColor};`}>
      Hawai‘i Mobile Food Foundation
    </span>
  )}
</span>

---
import { getCollection } from "astro:content";
import ProgramCard from "./ProgramCard.astro";
import SectionHeading from "./ui/SectionHeading.astro";

const programs = (await getCollection("programs")).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section id="programs" class="section bg-mist">
  <div class="container-x">
    <SectionHeading eyebrow="Alongside the show">
      What else<br/>
      <span class="italic text-ulu">we’re building</span> for vendors.
    </SectionHeading>

    <p class="mt-6 max-w-2xl text-stone text-lg">
      The podcast is the front door. These are the rooms behind it — practical work
      we’re building so the trucks have more than a story; they have help.
    </p>

    <div class="mt-14 grid gap-6 md:grid-cols-2">
      {programs.map((p) => (
        <ProgramCard
          title={p.data.title}
          body={p.data.body}
          cta={p.data.cta}
          audience={p.data.audience}
          icon={p.data.icon}
          meta={p.data.meta}
        />
      ))}
    </div>
  </div>
</section>

---
import { getCollection } from "astro:content";
const voices = (await getCollection("voices")).sort((a, b) => a.data.order - b.data.order);
---
<section class="section section-soft">
  <div class="container-x">
    <div class="text-center max-w-[720px] mx-auto mb-14">
      <span class="eyebrow">What we’re hearing</span>
      <h2 class="h2-display" style="margin-bottom: 16px;">
        The kind of thing you only get if you sit down.
      </h2>
      <p class="font-sans text-[18px] leading-[1.55]" style="color: var(--color-ink-soft);">
        Things vendors have told us off-cuff — the lines you don’t hear in a food review.
        Used with permission. Names withheld where requested. The full versions land in
        the podcast.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {voices.map((v) => (
        <figure class="card-soft p-7 md:p-8 flex flex-col bg-paper relative">
          <span aria-hidden="true"
                class="accent-script absolute -top-3 left-6 text-[64px] leading-none select-none"
                style="color: var(--color-brand-yellow); text-shadow: 2px 2px 0 var(--color-ink);">“</span>
          <blockquote class="font-sans text-[19px] leading-[1.4] font-medium mt-4 mb-5" style="color: var(--color-ink); text-wrap: balance;">
            {v.data.quote}
          </blockquote>
          <figcaption class="mt-auto pt-4 border-t border-ink/10">
            <p class="font-sans font-bold text-[14px]" style="color: var(--color-ink);">{v.data.attribution}</p>
            <p class="font-sans text-[11px] uppercase tracking-[0.12em] mt-1" style="color: var(--color-ink-faint);">
              {v.data.island}{v.data.truck && ` · ${v.data.truck}`}
            </p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
